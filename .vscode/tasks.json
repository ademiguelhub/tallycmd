{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Solution",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/Tallycmd.slnx"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Rebuild Solution",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/Tallycmd.slnx",
                "-t:Rebuild"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "EF: Check Changes",
            "type": "shell",
            "command": "dotnet ef migrations has-pending-model-changes --project Tallycmd.Api",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "EF: Add Migration",
            "type": "shell",
            "command": "dotnet ef migrations add ${input:migrationName} --project Tallycmd.Api -o Data/Migrations",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "EF: Remove Migration",
            "type": "shell",
            "command": "dotnet ef migrations remove --project Tallycmd.Api",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "EF: Check Database",
            "type": "shell",
            "command": "dotnet ef migrations list --project Tallycmd.Api",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "EF: Migrate Database",
            "type": "shell",
            "command": "dotnet ef database update --project Tallycmd.Api",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "[TODO] EF: Migrate Database To",
            "type": "shell",
            "command": "",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "EF: Drop Database",
            "type": "shell",
            "command": "dotnet ef database drop --project Tallycmd.Api",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ],
    "inputs": [
        {
            "id": "migrationName",
            "type": "promptString",
            "description": "Enter migration name",
            "default": "NewMigration"
        }
    ]
}